   "source": [
    "%sql\n",
    "WITH source AS (\n",
    "\n",
    "  SELECT *\n",
    "  FROM lego_brickbase.bronze.raw_colors\n",
    "  WHERE is_current = true\n",
    "  AND is_deleted = false\n",
    "\n",
    "),\n",
    "\n",
    " renamed AS (\n",
    "\n",
    "  SELECT\n",
    "    id AS color_key,\n",
    "    id,\n",
    "    name,\n",
    "    rgb,\n",
    "    is_trans\n",
    "  FROM source\n",
    "\n",
    ")\n",
    "\n",
    "SELECT * FROM renamed"
   ]
